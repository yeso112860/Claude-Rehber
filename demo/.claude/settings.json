{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Write",
      "Edit",
      "Bash(npm run dev)",
      "Bash(npm install)",
      "Bash(npm run build)",
      "Bash(npx tsc --noEmit)",
      "Bash(curl *localhost*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git add*)",
      "Bash(git commit*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(npm publish*)",
      "Bash(git push*)",
      "Bash(git rebase*)",
      "Bash(git reset --hard*)",
      "Bash(DROP TABLE*)",
      "Bash(DELETE FROM*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$TOOL_INPUT\" | grep -qE '(rm -rf|DROP TABLE|DELETE FROM.*WHERE 1=1|shutdown|format c)'; then echo 'TEHLIKELI KOMUT ENGELLENDI' >&2; exit 2; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"Degistirilen dosya: $TOOL_RESULT\" >> progress.md"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f progress.md ]; then echo '⚠ DEVAM EDEN GOREV VAR: progress.md dosyasini oku ve kaldigin yerden devam et'; fi"
          }
        ]
      }
    ]
  }
}